{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. CMake Configure",
            "type": "process",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build_win",
                "-G", "MinGW Makefiles",
                "-D", "CMAKE_C_COMPILER=C:/msys64/mingw64/bin/gcc.exe",
                "-D", "CMAKE_CXX_COMPILER=C:/msys64/mingw64/bin/g++.exe",
                "-D", "CMAKE_MAKE_PROGRAM=C:/msys64/mingw64/bin/mingw32-make.exe"
            ],
            "options": { "cwd": "${workspaceFolder}" }
        },
        {
            "label": "2. CMake Build",
            "type": "process",
            "command": "cmake",
            "args": [ "--build", "build_win" ],
            "dependsOn": "1. CMake Configure"
        },
        {
            "label": "Build & Run Raylib App",
            "type": "process",
            "command": "${workspaceFolder}/build_win/DinPlacer.exe",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "2. CMake Build"
        },
        {
            "label": "Alleen Build",
            "type": "process",
            "command": "cmake",
            "args": [ "--build", "build_win" ],
            "group": "build"
        },
        {
            "label": "Alleen Run",
            "type": "process",
            "command": "${workspaceFolder}/build_win/DinPlacer.exe"
        }
    ]
}
